# ─── Database ────────────────────────────────────────────────────
# PostgreSQL connection string (local Docker, Neon, RDS, etc.)
DATABASE_URL=""

# ─── JWT ─────────────────────────────────────────────────────────
# Generate strong secrets: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_token_secret_here
JWT_REFRESH_SECRET=your_refresh_token_secret_here

# ─── App ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# Frontend origin for CORS (match the URL where Vite runs in dev)
CLIENT_URL=http://localhost:5173
